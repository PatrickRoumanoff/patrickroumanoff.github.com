{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(bundle install*)",
      "Bash(bundle exec jekyll *)",
      "Bash(jekyll *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(./.env*)"
    ]
  }
}
